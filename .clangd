---
# global configuration

Index:
  Background: Build
  StandardLibrary: false

CompilationDatabase:
  PreamblePolicy: Skip
Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
    [
    # 1. 先禁用所有，从一个干净的环境开始
    # 2. 【核心】启用 C++ 核心准则，学习编写正确的C++
      "cppcoreguidelines-*",
    # 3. 【安全】启用所有“易错问题”检查，避免常见Bug
      "bugprone-*",

    # 4. 【学习】启用所有“代码现代化”检查，学习现代C++语法
      "modernize-*",
    ]
    Remove:
    [
      "bugprone-easily-swappable-parameters",
      "cppcoreguidelines-pro-bounds-pointer-arithmetic", # 允许指针运算
      "cppcoreguidelines-avoid-magic-numbers", # 允许数字
      "cppcoreguidelines-avoid-c-arrays", # 允许C风格数组
      "cppcoreguidelines-pro-bounds-constant-array-index", # 允许常量数组下标
      "modernize-avoid-c-arrays", # 允许C风格数组
      "cppcoreguidelines-owning-memory", # 允许裸指针管理内存
      "cppcoreguidelines-avoid-non-const-global-variables", # 允许非常量全局变量
      "cppcoreguidelines-pro-type-cstyle-cast", # 允许C风格强制转换 # 关闭dllimport/export警告
      "cppcoreguidelines-non-private-member-variables-in-classes", # 允许类中非私有成员变量
      "cppcoreguidelines-pro-type-vararg", # 允许调用C风格的可变参数函数
    ]
    # CheckOptions:
    #   readability-identifier-naming.VariableCase: CamelCase
    FastCheckFilter: Loose

  Includes:
    IgnoreHeader: ["torch/torch.h"]
    AnalyzeAngledIncludes: false
  MissingIncludes: Strict
Completion:              # 代码补全设置部分
  AllScopes: true        # 启用所有作用域的代码补全
InlayHints:              # 代码提示设置部分
  Enabled: true          # 启用代码提示
  ParameterNames: true   # 显示参数名称提示
  DeducedTypes: true     # 显示推断类型提示
  Designators: true      # 显示设计器提示
Hover:
  ShowAKA: true

SemanticTokens:
  DisabledKinds: []
  DisabledModifiers: [
    "Static",
    "Abstract"]
