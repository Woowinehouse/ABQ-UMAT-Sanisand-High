# ref: https://clangd.llvm.org/config
# should create project-specific configuration in the root folder

If:
  PathMatch: [.*\.c, .*\.h, .*\.cpp, .*\.hpp, .*\.cc, .*\.hh]
CompileFlags:
  Add:
    - -std:c++20
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_SILENCE_ALL_CXX17_DEPRECATION_WARNINGS
    - -DWIN32
    - -D_WINDOWS
    - -U__OBJC__
    - -W3
    - -GR
    - -EHsc
    - -MTd
    - -Zi
    - -Ob0
    - -Od
    - -RTC1
    - -W4
    - -WX-
    - -wd4819
    - -wd5109
    - -Zc:preprocessor
    # Abaqus 路径
    - -IE:/ABAQUS2025/product/win_b64/code/include
    - -IE:/ABAQUS2025/product
    # libtorch
    - -ID:/libtorch/libtorch_cpus_2_11_0_release/include
    - -ID:/libtorch/libtorch_cpus_2_11_0_release/include/torch/csrc/api/include
    # gtest 路径
    - -IF:/VScode2026/Sanisand-high-cpp/third_party/googletest/googletest/include
    # mimalloc 路径
    - -IF:/VScode2026/Sanisand-high-cpp/third_party/mimalloc/include
    # 添加MSVC系统头文件路径
    - -ID:/LLVM/include
    - -IE:/VS2022/VC/Tools/MSVC/14.44.35207/include
    - -IC:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/ucrt
    - -IC:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/shared
    - -IC:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/um
    - -IC:/Program Files (x86)/Windows Kits/10/Include/10.0.26100.0/winrt
    # 添加项目下的路径
    - -IF:/VScode2026/ABQ-UMAT-Sanisand-High/src/cpp
    - -IF:/VScode2026/Sanisand-high-cpp/tests
  Remove:
    - -std*
  Compiler: clang-cl
Style:
  QuotedHeaders: ["src/.*"]
  AngledHeaders: ["third_party/.*", "3rd/.*"]

---
If:
  PathMatch: $^
  PathExclude: .*
CompileFlags:
  Add:
    - -std=[c++23/c17]
    - -x[c++/c++-header/c/c-header]
    - -isystem-after "absolute/include/path"
    - -D KEY=VALUE
  Remove:
    - -std*
    - -x*
  Compiler: clang[/++]
Style:
  QuotedHeaders: ["src/.*"]
  AngledHeaders: ["third-party/.*"]

